# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

ANTHROPIC_API_KEY=        # console.anthropic.com
SPOONACULAR_API_KEY=      # spoonacular.com/food-api (free tier available)
RESEND_API_KEY=           # resend.com/api-keys (free tier available)
EMAIL_RECIPIENT=          # email address to receive the weekly digest

# Kroger API — developer.kroger.com → My Applications (free)
KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
KROGER_LOCATION_ID=       # find via: GET https://api.kroger.com/v1/locations?filter.zipCode=XXXXX
